#!/usr/bin/env zsh
# braining — brainstorming launcher (inactive example, extras/launchers/)
#
# Only launchers inside launchers/ are considered active. This file is an
# example of the sourced-launcher pattern; it works in place via:
#   source extras/launchers/braining
# To make it an active, discoverable launcher, copy or move it instead:
#   cp extras/launchers/braining launchers/braining
# Path resolution below is self-detecting and requires no edits either way.
# Sets behavioural env vars that persist in your shell session until
# `superpowers` (or a manual unset) clears them.
#
# Follows the minimal launcher contract (see extras/launchers/template):
#   1. set CLAUDE_ROUTER_DEFAULT_MODELS
#   2. set CLAUDE_ROUTER_MODEL
#   3. source router/router_engine.zsh, call claude_router
#   4. exec claude (here: a slash-command, not raw passthrough)
# Everything else (default model list, behavioural env vars) is
# workflow-specific and owned entirely by this launcher, not the router.

_THIS="${${(%):-%x}:A}"
if [[ "${_THIS:h:t}" == 'launchers' && "${_THIS:h:h:t}" == 'extras' ]]; then
    _BRAINING_DIR="${_THIS:h:h:h}"   # extras/launchers/braining -> repo root
else
    _BRAINING_DIR="${_THIS:h:h}"     # launchers/braining        -> repo root
fi

# ── Default model list ────────────────────────────────────────────────────────
# One model per line. User additions are managed interactively or stored in
# $XDG_CONFIG_HOME/claude-router/user-models.txt.

typeset -a _BRAINING_DEFAULTS
_BRAINING_DEFAULTS=(
    "openrouter/auto"
    "cohere/north-mini-code"
    "deepseek/deepseek-v4-flash"
)

# ── Model selection ───────────────────────────────────────────────────────────
# Pass the default list to the router as a newline-joined env var, then signal
# the router to run the interactive picker.

export CLAUDE_ROUTER_DEFAULT_MODELS="${(F)_BRAINING_DEFAULTS}"
export CLAUDE_ROUTER_MODEL="__pick__"

# ── Load and run the router ───────────────────────────────────────────────────

source "${_BRAINING_DIR}/router/router_engine.zsh"  # _BRAINING_DIR = repo root
claude_router || return 1

# ── Claude behaviour ──────────────────────────────────────────────────────────

export CLAUDE_CODE_DISABLE_ADVISOR_TOOL=1
export CLAUDE_CODE_PLAN_MODE_INTERVIEW_PHASE=1

export SUPERPOWERS_MODIFIER="You are acting EXCLUSIVELY as a Feature Brainstorming and Polishing sparring partner.
- Do NOT generate code, write implementation plans, or invoke TDD tools.
- Your only goal is a conversational debate over feature mechanics, scope creep, and refinement.
- Pull relevant context from the project filesystem to understand the existing project state, but keep the output entirely conversational.
- Challenge my assertions, propose UX/DX polishing ideas, and debate the architectural necessity of the feature."

# ── Launch ────────────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
    exec claude "/brainstorming"
else
    exec claude "/brainstorming $*"
fi
